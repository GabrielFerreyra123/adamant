{
  "name": "adamant-generador-scripts",
  "version": "1.0.0",
  "description": "Generador de scripts Ruby para SketchUp: estructuras Steel Frame y Wood Frame + cómputo, presupuesto y lista de corte.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "validate": "node tools/validate.js",
    "validate:export": "node tools/validate-export.js",
    "gen": "node tools/gen-samples.js",
    "serve": "node -e \"const h=require('http'),f=require('fs');h.createServer((q,s)=>{s.setHeader('content-type','text/html');s.end(f.readFileSync('adamant-generador-scripts.html'))}).listen(5173,()=>console.log('http://localhost:5173'))\""
  },
  "keywords": [
    "steel-frame",
    "wood-framing",
    "sketchup",
    "ruby",
    "adamant"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.8",
    "three": "^0.180.0"
  }
}
