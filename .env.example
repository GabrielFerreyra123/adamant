# Variables de entorno del backend (cargarlas en Vercel → Project → Settings → Environment Variables).
# NUNCA commitear un .env real.

# Access Token de Mercado Pago. Desarrollo: el TEST-... · Producción: el APP_USR-...
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxx

# Secreto para firmar licencias. Generar uno propio largo y aleatorio, p.ej.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si se cambia, TODAS las licencias emitidas dejan de valer.
LICENSE_SECRET=cambiame-por-64-caracteres-aleatorios

# Precio del desbloqueo por proyecto, en ARS (solo el servidor lo conoce).
PRECIO_PROYECTO=20000

# URL pública de la app (para las back_urls del checkout). En Vercel: https://tu-proyecto.vercel.app
APP_URL=https://TU-DOMINIO.vercel.app
